PORT=5001

# ── Local development ─────────────────────────
MONGO_URI=mongodb://localhost:27017/netscope
REDIS_URL=redis://localhost:6379

# ── MongoDB Atlas (production) ────────────────
# Replace with your Atlas connection string:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/netscope?retryWrites=true&w=majority

# ── Redis (production) ────────────────────────
# REDIS_URL=rediss://:password@your-redis.upstash.io:6380  (Upstash free tier works great)

# ── Auth ──────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=netscope_super_secret_change_this_in_production
JWT_EXPIRES_IN=7d

